modules = ["python-3.10"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["git"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run netflix2trakt"

[[workflows.workflow]]
name = "Run netflix2trakt"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python run_smoke_test.py"
